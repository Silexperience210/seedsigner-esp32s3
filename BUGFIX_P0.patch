}
```

**Modifier** `get_fingerprint`:
```cpp
uint32_t BIP32::get_fingerprint(const ExtendedKey* key) {
    if (!key || !m_secp256k1) return 0;
    
    uint8_t hash1[32];
    uint8_t hash2[20];
    
    // HASH160 = SHA256 + RIPEMD160
    m_secp256k1->sha256(key->key + 33, 33, hash1);
    ripemd160(hash1, 32, hash2);
    
    return ((uint32_t)hash2[0] << 24) |
           ((uint32_t)hash2[1] << 16) |
           ((uint32_t)hash2[2] << 8) |
           (uint32_t)hash2[3];
}
```

