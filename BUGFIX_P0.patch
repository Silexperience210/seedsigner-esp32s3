## 3. FIX: BIP39 Bit Extraction (bip39.cpp)

**Remplacer** la fonction `generate_mnemonic_from_entropy` (lignes 56-81):

```cpp
for (size_t i = 0; i < num_words; i++) {
    // Calculate bit position
    size_t bit_offset = i * 11;
    size_t byte_offset = bit_offset / 8;
    size_t bit_shift = bit_offset % 8;
    
    uint16_t index;
    if (bit_shift <= 5) {
        // All 11 bits in two bytes
        index = ((bits[byte_offset] << 3) | (bits[byte_offset + 1] >> 5)) & 0x7FF;
        index = (index >> (8 - bit_shift)) & 0x7FF;
    } else {
        // Bits span three bytes
        index = ((bits[byte_offset] & ((1 << (8 - bit_shift)) - 1)) << (bit_shift - 5)) |
                (bits[byte_offset + 1] << (bit_shift - 5 - 8)) |
                (bits[byte_offset + 2] >> (16 - bit_shift));
    }
    
    // Ensure index is valid
    index &= 0x7FF;
    
    const char* word = index_to_word(index);
    if (!word) {
        output[0] = '\0';
        return false;
    }
    
    // Append word
    if (i > 0) {
        if (offset + 1 >= output_len) return false;
        output[offset++] = ' ';
    }
    
    size_t word_len = strlen(word);
    if (offset + word_len >= output_len) {
        output[0] = '\0';
        return false;
    }
    
    memcpy(output + offset, word, word_len);
    offset += word_len;
    output[offset] = '\0';
}
```

